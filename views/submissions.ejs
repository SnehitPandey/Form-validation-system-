<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="min-h-screen bg-slate-100 p-4 text-slate-900 sm:p-8">
    <main class="mx-auto max-w-6xl">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <h1 class="text-2xl font-black sm:text-3xl"><%= title %></h1>
        <a href="/" class="inline-flex rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700">Back to Form</a>
      </div>

      <div id="message"></div>

      <section id="editPanel" class="mb-4 hidden rounded-xl border border-cyan-200 bg-cyan-50 p-4">
        <h2 class="text-lg font-semibold text-cyan-900">Edit Entry</h2>
        <p class="mb-3 mt-1 text-sm text-cyan-800">Update and save record.</p>

        <form id="editForm" class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <input type="hidden" id="editId" />
          <input id="editUsername" placeholder="Username" class="rounded-lg border border-slate-300 px-3 py-2" />
          <input id="editEmail" placeholder="Email" class="rounded-lg border border-slate-300 px-3 py-2" />
          <input id="editAge" type="number" placeholder="Age" class="rounded-lg border border-slate-300 px-3 py-2" />
          <select id="editGender" class="rounded-lg border border-slate-300 px-3 py-2">
            <option value="">Select gender</option>
            <option value="male">Male</option>
            <option value="female">Female</option>
            <option value="other">Other</option>
          </select>
          <input id="editPassword" type="password" placeholder="Password" class="rounded-lg border border-slate-300 px-3 py-2" />
          <input id="editConfirmPassword" type="password" placeholder="Confirm Password" class="rounded-lg border border-slate-300 px-3 py-2" />
          <textarea id="editBio" rows="3" placeholder="Bio" class="sm:col-span-2 rounded-lg border border-slate-300 px-3 py-2"></textarea>

          <div class="sm:col-span-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
            <label class="rounded border border-slate-300 bg-white px-3 py-2 text-sm"><input type="checkbox" name="editInterests" value="coding" class="mr-2" />Coding</label>
            <label class="rounded border border-slate-300 bg-white px-3 py-2 text-sm"><input type="checkbox" name="editInterests" value="design" class="mr-2" />Design</label>
            <label class="rounded border border-slate-300 bg-white px-3 py-2 text-sm"><input type="checkbox" name="editInterests" value="music" class="mr-2" />Music</label>
            <label class="rounded border border-slate-300 bg-white px-3 py-2 text-sm"><input type="checkbox" name="editInterests" value="sports" class="mr-2" />Sports</label>
          </div>

          <label class="sm:col-span-2 text-sm"><input id="editAgree" type="checkbox" class="mr-2" />I agree to the terms and conditions.</label>

          <div class="sm:col-span-2 flex gap-2">
            <button type="submit" class="rounded-lg bg-cyan-700 px-4 py-2 text-sm font-semibold text-white">Save Changes</button>
            <button type="button" onclick="closeEditPanel()" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Cancel</button>
          </div>
        </form>
      </section>

      <div class="mb-4 flex items-center justify-between">
        <p class="text-sm text-slate-600">Data loaded....</p>
        <button onclick="fetchEntries()" class="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700">Refresh</button>
      </div>

      <div id="entriesContainer" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3"></div>
    </main>

    <script>
      function showMessage(type, title, lines = []) {
        const styles =
          type === "error"
            ? "border-rose-300 bg-rose-50 text-rose-900"
            : "border-emerald-300 bg-emerald-50 text-emerald-900";
        const list = lines.length ? `<ul class="mt-2 list-inside list-disc text-sm">${lines.map((line) => `<li>${line}</li>`).join("")}</ul>` : "";
        document.getElementById("message").innerHTML = `<div class="mb-4 rounded-lg border px-4 py-3 ${styles}"><p class="font-semibold">${title}</p>${list}</div>`;
      }

      function clearMessage() {
        document.getElementById("message").innerHTML = "";
      }

      function getEditPayload() {
        return {
          username: document.getElementById("editUsername").value,
          email: document.getElementById("editEmail").value,
          age: document.getElementById("editAge").value,
          gender: document.getElementById("editGender").value,
          bio: document.getElementById("editBio").value,
          agree: document.getElementById("editAgree").checked,
          password: document.getElementById("editPassword").value,
          confirmPassword: document.getElementById("editConfirmPassword").value,
          interests: Array.from(document.querySelectorAll('input[name="editInterests"]:checked')).map((el) => el.value),
        };
      }

      function closeEditPanel() {
        document.getElementById("editPanel").classList.add("hidden");
      }

      async function fetchEntries() {
        const container = document.getElementById("entriesContainer");
        container.innerHTML = `<div class="rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-600">Loading...</div>`;

        try {
          const response = await fetch("/api/submissions");
          const data = await response.json();

          if (!data.items.length) {
            container.innerHTML = `<div class="rounded-xl border border-slate-200 bg-white p-6 text-slate-700 shadow-sm">No submissions yet.</div>`;
            return;
          }

          container.innerHTML = data.items
            .map(
              (entry) => `
                <article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                  <p class="font-bold text-slate-900">#${entry.id} - ${entry.username}</p>
                  <p class="mt-2 text-sm"><span class="font-semibold">Email:</span> ${entry.email}</p>
                  <p class="text-sm"><span class="font-semibold">Age:</span> ${entry.age}</p>
                  <p class="text-sm"><span class="font-semibold">Gender:</span> ${entry.gender}</p>
                  <p class="text-sm"><span class="font-semibold">Interests:</span> ${entry.interests.join(", ")}</p>
                  <p class="text-sm"><span class="font-semibold">Bio:</span> ${entry.bio}</p>
                  <p class="text-sm"><span class="font-semibold">Password:</span> ${"*".repeat(Math.max((entry.password || "").length, 8))}</p>
                  <p class="text-sm"><span class="font-semibold">Password Strength:</span> ${entry.passwordStrength}</p>
                  <p class="mt-2 text-xs text-slate-500">Updated: ${entry.updatedAt}</p>
                  <div class="mt-3 flex gap-2">
                    <button onclick="startEdit(${entry.id})" class="rounded border border-cyan-300 bg-cyan-50 px-2 py-1 text-xs font-semibold text-cyan-800">Edit</button>
                    <button onclick="deleteEntry(${entry.id})" class="rounded border border-rose-300 bg-rose-50 px-2 py-1 text-xs font-semibold text-rose-800">Delete</button>
                  </div>
                </article>
              `
            )
            .join("");
        } catch {
          container.innerHTML = `<div class="rounded-xl border border-rose-300 bg-rose-50 p-4 text-sm text-rose-700">Failed to load entries.</div>`;
        }
      }

      async function startEdit(id) {
        clearMessage();
        try {
          const response = await fetch(`/api/submissions/${id}`);
          if (!response.ok) {
            showMessage("error", "Fetch Error", ["Unable to load this entry."]);
            return;
          }
          const entry = await response.json();

          document.getElementById("editId").value = entry.id;
          document.getElementById("editUsername").value = entry.username;
          document.getElementById("editEmail").value = entry.email;
          document.getElementById("editAge").value = entry.age;
          document.getElementById("editGender").value = entry.gender;
          document.getElementById("editBio").value = entry.bio;
          document.getElementById("editAgree").checked = !!entry.agree;
          document.getElementById("editPassword").value = "";
          document.getElementById("editConfirmPassword").value = "";

          document.querySelectorAll('input[name="editInterests"]').forEach((checkbox) => {
            checkbox.checked = entry.interests.includes(checkbox.value);
          });

          document.getElementById("editPanel").classList.remove("hidden");
          window.scrollTo({ top: 0, behavior: "smooth" });
        } catch {
          showMessage("error", "Fetch Error", ["Unable to load this entry."]);
        }
      }

      async function deleteEntry(id) {
        if (!confirm("Delete this record?")) return;

        try {
          const response = await fetch(`/api/submissions/${id}`, { method: "DELETE" });
          if (!response.ok) {
            showMessage("error", "Delete Failed", ["Could not delete this entry."]);
            return;
          }
          showMessage("success", "Deleted", ["Entry deleted successfully."]);
          fetchEntries();
        } catch {
          showMessage("error", "Delete Failed", ["Could not delete this entry."]);
        }
      }

      document.getElementById("editForm").addEventListener("submit", async (event) => {
        event.preventDefault();

        const id = document.getElementById("editId").value;
        if (!id) return;

        try {
          const response = await fetch(`/api/submissions/${id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(getEditPayload()),
          });
          const data = await response.json();
          if (!response.ok) {
            showMessage("error", "Validation Failed", data.errors || [data.error || "Update failed."]);
            return;
          }

          showMessage("success", "Updated", ["Entry updated successfully."]);
          closeEditPanel();
          fetchEntries();
        } catch {
          showMessage("error", "Update Failed", ["Could not update this entry."]);
        }
      });

      fetchEntries();
    </script>
  </body>
</html>
