<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      .pop-in {
        animation: popIn 520ms ease;
      }

      @keyframes popIn {
        from {
          opacity: 0;
          transform: translateY(12px) scale(0.98);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-emerald-100 via-cyan-50 to-sky-100 p-4 text-slate-900 sm:p-8">
    <main class="pop-in mx-auto max-w-2xl rounded-2xl border border-emerald-200 bg-white p-6 shadow-xl sm:p-8">
      <h1 class="text-2xl font-black text-emerald-800"><%= title %></h1>
      <p class="mt-2 text-sm text-slate-600">Your response is saved.</p>

      <div class="mt-5 grid gap-2 rounded-xl bg-slate-50 p-4 text-sm sm:grid-cols-2">
        <p><span class="font-semibold">Stored submissions:</span> <%= totalSubmissions %></p>
        <p><span class="font-semibold">Saved at:</span> <%= user.timestamp %></p>
        <p><span class="font-semibold">Username:</span> <%= user.username %></p>
        <p><span class="font-semibold">Email:</span> <%= user.email %></p>
        <p><span class="font-semibold">Age:</span> <%= user.age %></p>
        <p><span class="font-semibold">Gender:</span> <%= user.gender %></p>
        <p class="sm:col-span-2"><span class="font-semibold">Interests:</span> <%= user.interests.join(", ") %></p>
        <p class="sm:col-span-2"><span class="font-semibold">Bio:</span> <%= user.bio %></p>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a class="rounded-lg bg-emerald-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-emerald-800" href="/">Submit another response</a>
        <a class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100" href="/submissions">View all submissions</a>
      </div>
    </main>
  </body>
</html>
